struct Boss {
    id: int,
    hp: int,
    shield: int
}

print("=== ЛОГ СИСТЕМЫ: Инициализация рейда ===")

// Оборачиваем битву в блок if, чтобы создать локальную область (комнату босса)
if 1 {
    print("-> Игрок зашел в комнату босса")
    
    // Создаем босса: ID=777, HP=1000, Shield=300
    b := Boss{777, 1000, 300}
    
    print("-> Спавн босса! Текущие щиты: ", b.shield)
    print("-> КРИТИЧЕСКИЙ УДАР ПО БОССУ! Наносим 500 урона")
    
    // Рассчитываем остаток щита и здоровья
    // Сначала урон летит в щит, а остаток — в HP
    damage := 500
    b.hp = b.hp + b.shield - damage
    b.shield = 0
    
    print("-> Щиты уничтожены! Остаток здоровья босса: ", b.hp)
    print("-> Игрок победил и выходит из комнаты...")
    
    // Тут блок закрывается, и CodeX должен автоматически вызвать деструктор босса
}

print("=== ЛОГ СИСТЕМЫ: Рейд завершен, память сервера чиста ===")